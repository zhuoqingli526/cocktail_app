<div>
  <div>
    <h1>
      List of all cocktail ingredients
    </h1>
  </div>
</div>

<hr>

<div>
  <div>
    <h2>
      Add a new cocktail ingredient
    </h2>

    <form action="/insert_cocktail_ingredient" method="post">
      <div>
        <label for="cocktail_id_box">
          Cocktail
        </label>

        <input type="text" id="cocktail_id_box" name="query_cocktail_id">
      </div>

      <div>
        <label for="ingredient_id_box">
          Ingredient
        </label>

        <input type="text" id="ingredient_id_box" name="query_ingredient_id">
      </div>

      <div>
        <label for="unit_ml_box">
          Unit ml
        </label>

        <input type="text" id="unit_ml_box" name="query_unit_ml">
      </div>

      <button>
        Create cocktail ingredient
      </button>
    </form>
  </div>
</div>

<hr>
<div>
  <div>
    <table border="1">
      <tr>
        <th>
          ID
        </th>

        <th>
          Cocktail
        </th>

        <th>
          Ingredient
        </th>

        <th>
          Unit ml
        </th>

        <th>
          Created at
        </th>

        <th>
          Updated at
        </th>

        <th>
        </th>
      </tr>

      <% @list_of_cocktail_ingredients.each do |a_cocktail_ingredient| %>
      <tr>
        <td>
          <%= a_cocktail_ingredient.id %>
        </td>

        <td>
          <%= a_cocktail_ingredient.cocktail_id %>
        </td>

        <td>
          <%= a_cocktail_ingredient.ingredient_id %>
        </td>

        <td>
          <%= a_cocktail_ingredient.unit_ml %>
        </td>

        <td>
          <%= time_ago_in_words(a_cocktail_ingredient.created_at) %> ago
        </td>
        <td>
          <%= time_ago_in_words(a_cocktail_ingredient.updated_at) %> ago
        </td>

        <td>
          <a href="/cocktail_ingredients/<%= a_cocktail_ingredient.id %>">
            Show details
          </a>
        </td>
      </tr>
      <% end %>
    </table>
  </div>
</div>

<hr>
