<div class="container" style="max-width: 700px; margin: 40px auto;">
  <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
    <a href="/ingredients" style="color: #94a3b8; text-decoration: none; font-weight: bold;">← Back to Library</a>
    <a href="/delete_ingredient/<%= @the_ingredient.id %>" style="color: #e53e3e; text-decoration: none; font-size: 0.9rem;">Delete</a>
  </div>

  <div class="profile-header-card" style="text-align: left; padding: 40px;">
    <div class="ingredient-abv-pill" style="font-size: 0.9rem; padding: 5px 12px; margin-bottom: 20px;">
      <%= @the_ingredient.abv %>% Alcohol by Volume
    </div>
    <h1 class="brand-title" style="font-size: 2.5rem; margin-bottom: 20px;"><%= @the_ingredient.name %></h1>
    
    <div style="margin-bottom: 30px;">
      <h4 style="color: #D4AF37; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Flavor Profile</h4>
      <p style="font-size: 1.1rem; color: #3E3A35; line-height: 1.6;"><%= @the_ingredient.description %></p>
    </div>

    <div style="background: #fdfaf2; padding: 15px; border-radius: 12px; border-left: 3px solid #D4AF37;">
      <span style="font-size: 0.8rem; color: #9e958a;">Category:</span>
      <strong style="color: #3E3A35;"><%= @the_ingredient.ingredient_category&.name || "Uncategorized" %></strong>
    </div>
  </div>

  <div class="glass-form-card" style="margin-top: 40px;">
    <h3 class="brand-title" style="font-size: 1.2rem; margin-bottom: 20px;">Edit Information</h3>
    <form action="/modify_ingredient/<%= @the_ingredient.id %>" method="post" class="custom-form">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="query_name" value="<%= @the_ingredient.name %>" class="form-control">
        </div>
        <div class="form-group">
          <label>ABV</label>
          <input type="text" name="query_abv" value="<%= @the_ingredient.abv %>" class="form-control">
        </div>
      </div>
      <div class="form-group" style="margin-top: 15px;">
        <label>Description</label>
        <textarea name="query_description" rows="3" class="form-control"><%= @the_ingredient.description %></textarea>
      </div>
      <button class="btn-follow-gold" style="width: 100%; margin-top: 20px;">Update Details</button>
    </form>
  </div>
</div>
