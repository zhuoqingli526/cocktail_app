<div>
  <div>
    <h2>
      Add a new ingredient
    </h2>

    <form action="/insert_ingredient" method="post">
      <div>
        <label for="name_box">
          Name
        </label>

        <input type="text" id="name_box" name="query_name">
      </div>

      <div>
        <label for="description_box">
          Description
        </label>

        <input type="text" id="description_box" name="query_description">
      </div>

      <div>
        <label for="abv_box">
          Abv
        </label>

        <input type="text" id="abv_box" name="query_abv">
      </div>

      <div>
        <label for="ingredient_category_id_box">
          Ingredient category
        </label>

        <input type="text" id="ingredient_category_id_box" name="query_ingredient_category_id">
      </div>

      <button>
        Create ingredient
      </button>
    </form>
  </div>
</div>

<hr>


<div>
  <div>
    <h1>
      List of all ingredients
    </h1>
  </div>
</div>


<% IngredientCategory.order(:name).each do |category| %>
  <h2><%= category.name %></h2>

  <% ingredients = @list_of_ingredients.select { |i| i.ingredient_category_id == category.id } %>

  <% if ingredients.any? %>
    <table border="1">
      <tr>
        <th>Name</th>
        <th>Description</th>
        <th>Abv</th>
      </tr>

      <% ingredients.each do |an_ingredient| %>
        <tr>
          <td><%= an_ingredient.name %></td>
          <td><%= an_ingredient.description %></td>
          <td><%= an_ingredient.abv %></td>
        </tr>
      <% end %>
    </table>
  <% else %>
    <p>No ingredients in this category.</p>
  <% end %>

  <hr>
<% end %>
