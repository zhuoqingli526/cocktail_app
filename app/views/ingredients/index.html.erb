<div class="container" style="max-width: 1000px; margin: 0 auto; padding: 20px;">
  
  <div class="glass-form-card">
    <h2 class="brand-title" style="font-size: 1.5rem; margin-bottom: 20px;">✨ Add New Ingredient</h2>
    <form action="/insert_ingredient" method="post" class="custom-form">
      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="query_name" placeholder="e.g. Campari" class="form-control">
        </div>
        <div class="form-group">
          <label>ABV (%)</label>
          <input type="text" name="query_abv" placeholder="25" class="form-control">
        </div>
        <div class="form-group">
          <label>Category</label>
          <select name="query_ingredient_category_id" class="form-control">
            <% IngredientCategory.all.each do |category| %>
              <option value="<%= category.id %>"><%= category.name %></option>
            <% end %>
          </select>
        </div>
      </div>
      <div class="form-group" style="margin-top: 15px;">
        <label>Description</label>
        <textarea name="query_description" rows="2" class="form-control" placeholder="Brief notes on flavor profile..."></textarea>
      </div>
      <button class="btn-follow-gold" style="width: 100%; margin-top: 20px; padding: 12px;">Create Ingredient</button>
    </form>
  </div>

  <h1 class="brand-title" style="text-align: center; font-size: 2.5rem; margin-bottom: 40px;">Ingredient Library</h1>

  <% IngredientCategory.order(:name).each do |category| %>
    <h2 class="category-divider"><%= category.name %></h2>
    
    <% ingredients = @list_of_ingredients.select { |i| i.ingredient_category_id == category.id } %>
    
    <div class="cocktail-grid" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px;">
      <% if ingredients.any? %>
        <% ingredients.each do |an_ingredient| %>
          <div class="ingredient-card">
            <div>
              <div class="ingredient-name"><%= an_ingredient.name %></div>
              <div class="ingredient-abv-pill"><%= an_ingredient.abv %>% ABV</div>
              <p style="font-size: 0.85rem; color: #64748b; line-height: 1.4;">
                <%= truncate(an_ingredient.description, length: 80) %>
              </p>
            </div>
            <div style="margin-top: 15px; border-top: 1px solid #f1f1f1; pt-10px; padding-top: 10px;">
              <a href="/ingredients/<%= an_ingredient.id %>" style="color: #D4AF37; font-size: 0.8rem; font-weight: bold; text-decoration: none;">View Details →</a>
            </div>
          </div>
        <% end %>
      <% else %>
        <p style="color: #94a3b8; font-style: italic; font-size: 0.9rem;">Empty shelf...</p>
      <% end %>
    </div>
  <% end %>
</div>
