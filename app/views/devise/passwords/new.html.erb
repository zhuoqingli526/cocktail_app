<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">
      <div style="font-size: 3rem; margin-bottom: 10px;">🔑</div>
      <h1 class="brand-title" style="font-size: 1.8rem; margin: 0;">忘记密码了？</h1>
      <p style="color: #9e958a; font-size: 0.9rem; margin-top: 10px; line-height: 1.5;">
        别担心，请输入您的注册邮箱，我们将为您发送一条重置链接。
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="auth-field">
        <%= f.label :email, "电子邮箱" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input", placeholder: "you@example.com" %>
      </div>

      <div class="actions" style="margin-top: 30px;">
        <%= f.submit "发送重置指令", class: "btn-follow-gold", style: "width: 100%; padding: 12px;" %>
      </div>
    <% end %>

    <div class="auth-footer">
      想起来了？ <%= link_to "返回登录", new_session_path(resource_name), style: "color: #D4AF37; font-weight: 600; text-decoration: none;" %>
    </div>
  </div>
</div>
