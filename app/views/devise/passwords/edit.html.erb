<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">
      <h1 class="brand-title" style="font-size: 1.8rem; margin: 0;">设置新密码</h1>
      <p style="color: #9e958a; font-size: 0.9rem; margin-top: 10px;">请确保您的新密码足够安全。</p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="auth-field">
        <%= f.label :password, "新密码" %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "auth-input" %>
        <% if @minimum_password_length %>
          <span class="auth-helper">至少需要 <%= @minimum_password_length %> 个字符</span>
        <% end %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "确认新密码" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input" %>
      </div>

      <div class="actions" style="margin-top: 30px;">
        <%= f.submit "更新并登录", class: "btn-follow-gold", style: "width: 100%; padding: 12px;" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
