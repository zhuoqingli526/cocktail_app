<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">
      <h1 class="brand-title" style="font-size: 2.2rem; margin: 0;">Welcome Back</h1>
      <p style="color: #9e958a; font-size: 0.9rem; margin-top: 10px;">登录您的调酒师账户</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="auth-field">
        <%= f.label :email, "电子邮箱" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input" %>
      </div>

      <div class="auth-field">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <%= f.label :password, "密码", style: "margin-bottom: 8px;" %>
          <%= link_to "忘记密码？", new_password_path(resource_name), style: "font-size: 0.75rem; color: #D4AF37; text-decoration: none; margin-bottom: 8px;" %>
        </div>
        <%= f.password_field :password, autocomplete: "current-password", class: "auth-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 20px;">
          <%= f.check_box :remember_me, style: "accent-color: #D4AF37;" %>
          <%= f.label :remember_me, "记住我", style: "font-size: 0.85rem; color: #666; margin: 0;" %>
        </div>
      <% end %>

      <div class="actions">
        <%= f.submit "登录", class: "btn-follow-gold", style: "width: 100%; padding: 12px;" %>
      </div>
    <% end %>

    <div class="auth-footer">
      还没有账户？ <%= link_to "立即加入", new_registration_path(resource_name), style: "color: #D4AF37; font-weight: 600; text-decoration: none;" %>
    </div>
  </div>
</div>
