<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">
      <h1 class="brand-title" style="font-size: 2rem; margin: 0;">The Mixology Club</h1>
      <p style="color: #9e958a; font-size: 0.9rem; margin-top: 10px;">加入社区，开启你的调酒之旅</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="auth-field">
        <%= f.label :username, "用户名" %>
        <%= f.text_field :username, autofocus: true, class: "auth-input", placeholder: "给调酒师起个名字" %>
      </div>

      <div class="auth-field">
        <%= f.label :email, "电子邮箱" %>
        <%= f.email_field :email, autocomplete: "email", class: "auth-input", placeholder: "you@example.com" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, "密码" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "auth-input" %>
        <% if @minimum_password_length %>
          <span class="auth-helper">至少需要 <%= @minimum_password_length %> 个字符</span>
        <% end %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "确认密码" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input" %>
      </div>

      <div class="actions">
        <%= f.submit "创建账户", class: "btn-follow-gold", style: "width: 100%; padding: 12px; margin-top: 10px;" %>
      </div>
    <% end %>

    <div class="auth-footer">
      已有账户？ <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
