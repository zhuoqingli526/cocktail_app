<div class="chat-container">
  <div class="chat-header">
    <h1 class="chat-title">AI Bartender</h1>
    <p class="chat-subtitle">Your private mixology consultant</p>
  </div>

  <div class="chat-box">
    <div class="chat-history" id="chat-history">
      
      <%# 增加：如果没有消息，显示欢迎状态 %>
      <% if @messages.blank? %>
        <div class="chat-empty-state">
          <div class="empty-icon">🍸</div>
          <h3>Welcome to the Bar!</h3>
          <p>I'm your AI mixologist. Tell me what flavors you like, or ask for a classic recipe.</p>
        </div>
      <% else %>
        <% @messages.each do |msg| %>
          <div class="chat-message <%= msg.role == 'user' ? 'message-user' : 'message-ai' %>">
            <div class="message-avatar">
              <%= msg.role == 'user' ? 'U' : 'AI' %>
            </div>
            <div class="message-bubble">
              <%= msg.body %>
            </div>
          </div>
        <% end %>
      <% end %>

    </div>

    <div class="chat-suggestions">
      <button type="button" class="chip" onclick="fillAndSubmit('Give me a recipe for a classic Old Fashioned.')">🥃 Classic Old Fashioned</button>
      <button type="button" class="chip" onclick="fillAndSubmit('I have Vodka, Lemon, and Soda. What can I make?')">🍋 Ingredients Match</button>
      <button type="button" class="chip" onclick="fillAndSubmit('Tell me a fun history fact about the Martini.')">📖 Cocktail History</button>
    </div>

    <div class="chat-input-area">
      <form action="/cocktail_chat/send" method="post" class="chat-form" id="chat-form">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" name="query_session_id" value="<%= @session_id %>">
        
        <textarea name="query_body" id="chat-textarea" class="chat-textarea" rows="1" placeholder="Ask about a classic Negroni..." required></textarea>
        
        <button type="submit" class="btn-send">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576 6.636 10.07Zm6.787-8.201L1.591 6.602l4.339 2.76 7.494-7.493Z"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  // 保持滚动到底部的功能
  document.addEventListener("DOMContentLoaded", function() {
    var chatHistory = document.getElementById("chat-history");
    chatHistory.scrollTop = chatHistory.scrollHeight;
  });

  // 增加：点击快捷提示词，自动填入输入框并提交表单
  function fillAndSubmit(text) {
    var textarea = document.getElementById('chat-textarea');
    var form = document.getElementById('chat-form');
    
    if (textarea && form) {
      textarea.value = text;
      // 增加一点小延迟让用户看清填入的字，然后自动提交
      setTimeout(function() {
        form.submit();
      }, 300);
    }
  }
</script>
