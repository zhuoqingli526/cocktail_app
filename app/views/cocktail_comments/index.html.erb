<div>
  <div>
    <h1>
      List of all cocktail comments
    </h1>
  </div>
</div>

<hr>

<div>
  <div>
    <h2>
      Add a new cocktail comment
    </h2>

    <form action="/insert_cocktail_comment" method="post">
      <div>
        <label for="cocktail_id_box">
          Cocktail
        </label>

        <input type="text" id="cocktail_id_box" name="query_cocktail_id">
      </div>

      <div>
        <label for="user_id_box">
          User
        </label>

        <input type="text" id="user_id_box" name="query_user_id">
      </div>

      <button>
        Create cocktail comment
      </button>
    </form>
  </div>
</div>

<hr>
<div>
  <div>
    <table border="1">
      <tr>
        <th>
          ID
        </th>

        <th>
          Cocktail
        </th>

        <th>
          User
        </th>

        <th>
          Created at
        </th>

        <th>
          Updated at
        </th>

        <th>
        </th>
      </tr>

      <% @list_of_cocktail_comments.each do |a_cocktail_comment| %>
      <tr>
        <td>
          <%= a_cocktail_comment.id %>
        </td>

        <td>
          <%= a_cocktail_comment.cocktail_id %>
        </td>

        <td>
          <%= a_cocktail_comment.user_id %>
        </td>

        <td>
          <%= time_ago_in_words(a_cocktail_comment.created_at) %> ago
        </td>
        <td>
          <%= time_ago_in_words(a_cocktail_comment.updated_at) %> ago
        </td>

        <td>
          <a href="/cocktail_comments/<%= a_cocktail_comment.id %>">
            Show details
          </a>
        </td>
      </tr>
      <% end %>
    </table>
  </div>
</div>

<hr>
