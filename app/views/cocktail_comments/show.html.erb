<div class="creator-container">
  <div class="back-nav">
    <a href="/cocktail_comments">← Back to Feed</a>
  </div>

  <div class="form-card info-card">
    <div class="section-header">
      <span class="section-num">ID</span>
      <h3>Comment #<%= @the_cocktail_comment.id %> Details</h3>
      <div style="margin-left: auto;">
        <%= link_to "Delete Entry", "/delete_cocktail_comment/#{@the_cocktail_comment.id}", class: "btn-delete", style: "font-size: 0.8rem;", data: { confirm: "Are you sure?" } %>
      </div>
    </div>

    <div class="detail-display-grid">
      <div class="detail-unit">
        <label>Cocktail Source</label>
        <p>ID: <%= @the_cocktail_comment.cocktail_id %></p>
      </div>
      <div class="detail-unit">
        <label>Commenter</label>
        <p>User ID: <%= @the_cocktail_comment.user_id %></p>
      </div>
      <div class="detail-unit">
        <label>Timeline</label>
        <p>Created <%= time_ago_in_words(@the_cocktail_comment.created_at) %> ago</p>
        <p><small style="color: #94a3b8">Updated <%= time_ago_in_words(@the_cocktail_comment.updated_at) %> ago</small></p>
      </div>
    </div>
  </div>

  <div class="form-card">
    <div class="section-header">
      <span class="section-num">✎</span>
      <h3>Modify Comment</h3>
    </div>

    <form action="/modify_cocktail_comment/<%= @the_cocktail_comment.id %>" method="post" class="creative-form">
      <div class="input-row-grid">
        <div class="input-floating">
          <input type="text" id="cocktail_id_box" name="query_cocktail_id" value="<%= @the_cocktail_comment.cocktail_id %>" placeholder=" ">
          <label for="cocktail_id_box">Update Cocktail ID</label>
        </div>

        <div class="input-floating">
          <input type="text" id="user_id_box" name="query_user_id" value="<%= @the_cocktail_comment.user_id %>" placeholder=" ">
          <label for="user_id_box">Update User ID</label>
        </div>
      </div>

      <div class="form-footer" style="padding: 0;">
        <button class="btn-primary">Update Records</button>
      </div>
    </form>
  </div>
</div>
