<div class="profile-header-card">
  <div class="profile-avatar-big">
    <%= @the_user.username[0].upcase %>
  </div>
  <h1 class="brand-title" style="font-size: 2rem; margin-bottom: 10px;"><%= @the_user.username %></h1>
  <p style="color: #9e958a; max-width: 500px; margin: 0 auto;"><%= @the_user.bio %></p>

  <div class="profile-stats">
    <div class="stat-item">
      <span class="stat-value"><%= @the_user.cocktails.count %></span>
      <span class="stat-label">Created</span>
    </div>
    <div class="stat-item">
      <span class="stat-value"><%= @the_user.followers.count %></span>
      <span class="stat-label">Followers</span>
    </div>
    <div class="stat-item">
      <span class="stat-value"><%= @the_user.leaders.count %></span>
      <span class="stat-label">Following</span>
    </div>
  </div>
</div>

<nav class="user-tabs-nav">
  <a href="/users/<%= @the_user.id %>" class="tab-link">Created</a>
  <a href="/users/<%= @the_user.username %>/liked_cocktails" class="tab-link">Liked</a>
  <a href="/users/<%= @the_user.username %>/feed" class="tab-link active">Following Feed</a>
  <a href="/users/<%= @the_user.username %>/popular_picks" class="tab-link">Popular</a>
</nav>

<div class="section-header" style="margin-bottom: 20px;">
  <h2 style="font-family: 'Playfair Display', serif; color: var(--warm-charcoal);">Latest from Following</h2>
  <p style="font-size: 0.9rem; color: #94a3b8;"><%= @the_leader_cocktails.count %> new inspirations</p>
</div>

<div class="cocktail-grid">
  <% @the_leader_cocktails.each do |a_cocktail| %>
    <div class="cocktail-card-elegant">
      <a href="/cocktails/<%= a_cocktail.id %>" style="text-decoration: none; color: inherit;">
        <div class="card-image-wrapper">
          <img src="<%= a_cocktail.image_url.url %>" alt="<%= a_cocktail.cocktail_name %>">
          <div class="like-badge" style="position: absolute; bottom: 12px; right: 12px; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); color: white; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem;">
            ❤️ <%= a_cocktail.likes.count %>
          </div>
        </div>
        
        <div class="card-info">
          <span class="card-category" style="color: #C5A028; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">
            <%= a_cocktail.taste %> • <%= a_cocktail.abv %>% ABV
          </span>
          <h3 class="card-title" style="margin-top: 8px; font-weight: 700;"><%= a_cocktail.cocktail_name %></h3>
          <p style="font-size: 0.85rem; color: #64748b; line-height: 1.5; height: 3em; overflow: hidden; margin-bottom: 15px;">
            <%= a_cocktail.description %>
          </p>
          
          <div class="card-footer" style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #f8fafc; padding-top: 12px;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <div style="width: 24px; height: 24px; background: #F4EBD0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.6rem; color: #D4AF37; font-weight: bold;">
                <%= a_cocktail.user.username[0].upcase %>
              </div>
              <span style="font-size: 0.75rem; color: #3E3A35; font-weight: 600;"><%= a_cocktail.user.username %></span>
            </div>
            <span style="font-size: 0.7rem; color: #94a3b8;"><%= time_ago_in_words(a_cocktail.created_at) %> ago</span>
          </div>
        </div>
      </a>
    </div>
  <% end %>
</div>
