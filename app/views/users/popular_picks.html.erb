<div class="profile-header-card">
  </div>

<nav class="user-tabs-nav">
  <a href="/users/<%= @the_user.id %>" class="tab-link">Created</a>
  <a href="/users/<%= @the_user.username %>/liked_cocktails" class="tab-link">Liked</a>
  <a href="/users/<%= @the_user.username %>/feed" class="tab-link">Feed</a>
  <a href="/users/<%= @the_user.username %>/popular_picks" class="tab-link active">Popular</a>
</nav>

<div class="section-header" style="margin-bottom: 20px; text-align: center;">
  <h2 style="font-family: 'Playfair Display', serif; color: var(--warm-charcoal); font-size: 2rem;">Trending Now</h2>
  <p style="color: #C5A028; font-weight: bold; letter-spacing: 2px;">COMMUNITY FAVORITES</p>
</div>

<div class="cocktail-grid">
  <% @popular_cocktails.each_with_index do |a_cocktail, index| %>
    <div class="cocktail-card-elegant">
      <a href="/cocktails/<%= a_cocktail.id %>" style="text-decoration: none; color: inherit;">
        <div class="card-image-wrapper">
          <div class="rank-badge" style="position: absolute; top: 15px; left: 15px; background: <%= index < 3 ? '#D4AF37' : '#3E3A35' %>; color: white; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1rem; z-index: 10; border: 2px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.2);">
            <%= index + 1 %>
          </div>
          
          <img src="<%= a_cocktail.image_url.url %>" alt="<%= a_cocktail.cocktail_name %>">
          
          <div class="like-badge" style="position: absolute; bottom: 12px; right: 12px; background: rgba(197, 160, 40, 0.9); backdrop-filter: blur(4px); color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: bold;">
            🔥 <%= a_cocktail.likes.count %>
          </div>
        </div>
        
        <div class="card-info" style="background: linear-gradient(to bottom, #ffffff, #fdfaf2);">
          <span class="card-category" style="color: #C5A028; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">
            <%= a_cocktail.taste %> • Top Choice
          </span>
          <h3 class="card-title" style="margin-top: 8px; font-weight: 700;"><%= a_cocktail.cocktail_name %></h3>
          <p style="font-size: 0.85rem; color: #64748b; line-height: 1.5; height: 3em; overflow: hidden; margin-bottom: 15px;">
            <%= a_cocktail.description %>
          </p>
          
          <div class="card-footer" style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(212, 175, 55, 0.1); padding-top: 12px;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 0.75rem; color: #94a3b8;">Created by</span>
              <span style="font-size: 0.75rem; color: #3E3A35; font-weight: 600;"><%= a_cocktail.user.username %></span>
            </div>
          </div>
        </div>
      </a>
    </div>
  <% end %>
</div>
