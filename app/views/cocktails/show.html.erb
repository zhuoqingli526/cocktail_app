<div class="detail-container">
  <div class="nav-wrapper">
    <a href="/cocktails" class="back-btn-elegant">
      <div class="btn-icon-circle">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
      </div>
      <span class="btn-text">Back to Library</span>
    </a>
  </div>

  <div class="detail-layout">
    <div class="detail-visual">
      <img src="<%= @the_cocktail.image_url.url %>" class="hero-image">
    </div>

    <div class="detail-info">
      <div class="info-header">
        <h1 class="cocktail-name"><%= @the_cocktail.cocktail_name %></h1>
        <div class="info-meta">
          <span class="badge"><%= @the_cocktail.taste %></span>
          <span class="badge"><%= @the_cocktail.abv %>% ABV</span>
          <span class="creator">Created by <strong><%= @the_cocktail.user.username %></strong></span>
        </div>
      </div>

      <div class="info-section">
        <h4>The Story</h4>
        <p class="description"><%= @the_cocktail.description %></p>
      </div>

      <div class="info-section">
        <h4>Ingredients</h4>
        <ul class="ingredient-list">
          <% @the_cocktail.cocktail_ingredients.includes(:ingredient).each do |item| %>
            <li>
              <span class="ing-name"><%= item.ingredient.name %></span>
              <span class="ing-dots"></span>
              <span class="ing-amount"><%= item.unit_ml %> ml</span>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="info-section">
        <h4>Instructions</h4>
        <div class="instructions-box">
          <%= @the_cocktail.instructions %>
        </div>
      </div>

      <div class="action-bar">
        <% existing_like = @the_cocktail.likes.find_by(user_id: current_user.id) %>
        <% if existing_like %>
          <%= link_to "❤️ Unlike (#{@the_cocktail.likes.count})", "/delete_cocktail_like/#{existing_like.id}", class: "btn-action active" %>
        <% else %>
          <form action="/insert_cocktail_like" method="post" style="display:inline">
            <input type="hidden" name="query_cocktail_id" value="<%= @the_cocktail.id %>">
            <input type="hidden" name="query_user_id" value="<%= current_user.id %>">
            <button class="btn-action">🤍 Like (<%= @the_cocktail.likes.count %>)</button>
          </form>
        <% end %>

        <% if current_user == @the_cocktail.user %>
          <a href="/delete_cocktail/<%= @the_cocktail.id %>" class="btn-delete" onclick="return confirm('确定要删除吗？')">Delete</a>
        <% end %>
      </div>
    </div>
  </div>

  <section class="comments-section">
    <div class="comments-header">
      <h3>Comments <span class="comment-count">(<%= @the_cocktail.comments.count %>)</span></h3>
    </div>

    <div class="comments-list">
      <% @the_cocktail.comments.each do |c| %>
        <div class="comment-item-elegant">
          <div class="comment-avatar">
            <%= c.user.username[0].upcase %>
          </div>
          
          <div class="comment-content-wrapper">
            <div class="comment-user-meta">
              <span class="user-name"><%= c.user.username %></span>
              <span class="comment-date"><%= c.created_at.strftime("%b %d, %Y") %></span>
            </div>
            <div class="comment-text-body">
              <%= c.comment_text %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="comment-form-container">
      <form action="/insert_cocktail_comment" method="post" class="elegant-comment-form">
        <input type="hidden" name="query_cocktail_id" value="<%= @the_cocktail.id %>">
        <input type="hidden" name="query_user_id" value="<%= current_user.id %>">
        
        <div class="textarea-wrapper">
          <textarea name="query_body" placeholder="Share your tasting notes..." required></textarea>
          <button type="submit" class="btn-send-comment">
            Post
          </button>
        </div>
      </form>
    </div>
  </section>
</div>
