<div>
  <div>
    <h1>
      Cocktail Library
    </h1>
  </div>
</div>



<div>
  <div>
    <table border="1">
      <tr>

        <th>
          Cocktail name
        </th>

        <th>
          Image
        </th>

        <th>
          Description
        </th>

        <th>
          Instructions
        </th>

        <th>
          Abv
        </th>

        <th>
          Taste
        </th>

        <th>
          Creator
        </th>

        <th>
          Created at
        </th>

        <th>
          Likes
        </th>


        <th>
        </th>
      </tr>

      <% @list_of_cocktails.each do |a_cocktail| %>
      <tr>

        <td>
          <%= a_cocktail.cocktail_name %>
        </td>
        
        <td>
          <img src="<%= a_cocktail.image_url.url %>" width="200" height="300">
        </td>

        <td>
          <%= a_cocktail.description %>
        </td>

        <td>
          <%= a_cocktail.instructions %>
        </td>

        <td>
          <%= a_cocktail.abv %>
        </td>

        <td>
          <%= a_cocktail.taste %>
        </td>

        <td>
          <% the_user = a_cocktail.user %>
          <%= the_user.username %>
        </td>

        <td>
          <%= time_ago_in_words(a_cocktail.created_at) %> ago
        </td>

        <td>
          <%= a_cocktail.likes.count %>
        </td>

        <td>
          <a href="/cocktails/<%= a_cocktail.id %>">
            Show details
          </a>
        </td>
      </tr>
      <% end %>
    </table>
  </div>
</div>

<hr>
